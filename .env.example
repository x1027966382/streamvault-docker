# StreamVault 环境变量配置

# ===== 基础配置 =====
# 部署目录
STREAMVAULT_DIR=/vol1/1000/docker/streamvault

# 时区
TZ=Asia/Shanghai

# ===== 代理设置 =====
# 如需访问外网平台（抖音、YouTube 等），取消注释并填写代理地址
# HTTP_PROXY=http://192.168.5.9:7890
# HTTPS_PROXY=http://192.168.5.9:7890

# ===== 通知配置（可选） =====
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Server酱
SERVERCHAN_KEY=
# PushPlus
PUSHPLUS_TOKEN=
# 钉钉
DINGTALK_WEBHOOK=

# ===== Aria2 配置 =====
ARIA2_RPC_SECRET=streamvault_secret

# ===== Web 管理面板 =====
WEB_PANEL_PORT=28082
